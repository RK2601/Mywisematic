# MongoDB connection string (Atlas, Railway MongoDB, etc.)
# Use the standard (non-SRV) URI from Atlas if mongodb+srv fails on Windows.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/wisematic?retryWrites=true&w=majority

# Put real values in .env.local only — never commit secrets here.

# Used to sign admin session cookies (recommended in production)
AUTH_SECRET=replace-with-a-long-random-string

# Optional: required to create additional admin users after the first one
SETUP_SECRET=replace-with-another-random-string

# Optional: override API base URL (leave empty to use this app's local /api routes)
# NEXT_PUBLIC_API_BASE_URL=
